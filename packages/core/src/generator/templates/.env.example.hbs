# API configuration for {{apiName}}

# Optional override. Defaults to the URL from the OpenAPI spec.
API_BASE_URL={{baseUrl}}

{{#if hasAuth}}
# Auth scheme detected: {{auth.type}}{{#if auth.location}} via {{auth.location}} ({{auth.parameterName}}){{/if}}
{{#if (eq auth.type "oauth2")}}
# OAuth supports a ready-to-use access token, client credentials, or refresh-token renewal.
# If the token URL below is wrong or blank, set OAUTH_TOKEN_URL to your provider token endpoint.
OAUTH_TOKEN_URL={{auth.tokenUrl}}
# Optional override for requested OAuth scopes. Defaults to scopes discovered from the spec.
# OAUTH_SCOPES={{#if auth.scopes}}{{auth.scopes}}{{/if}}
# Client credentials flow:
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# Refresh-token renewal:
# OAUTH_REFRESH_TOKEN=
# Static token fallback:
{{auth.envVarName}}=
{{else}}
{{#if authRequired}}
# Required for authenticated endpoints.
{{auth.envVarName}}=replace-me
{{else}}
# Optional. Set this if you need access to authenticated endpoints.
# Leave blank to call public endpoints only.
{{auth.envVarName}}=
{{/if}}
{{/if}}
{{else}}
# No authentication scheme detected in the OpenAPI spec.
# Add custom env vars here if your deployment needs them.
{{/if}}

# Compatibility notes:
# - Verified request modes: JSON, x-www-form-urlencoded, multipart/form-data, text, and binary payloads.
# - Verified auth modes: header/query/cookie API keys, bearer tokens, basic auth, OAuth client credentials, and OAuth refresh-token renewal.
#
# Resilience (all optional, defaults shown)
# Max retry attempts after the initial call (0 = no retries).
# RESILIENCE_RETRY_MAX=3

# Base delay in ms for exponential backoff.
# RESILIENCE_RETRY_BASE_MS=500

# Maximum delay cap in ms for any single retry wait.
# RESILIENCE_RETRY_MAX_MS=30000

# Number of consecutive failures before the circuit breaker opens per host.
# RESILIENCE_CB_THRESHOLD=5

# How long (ms) the circuit breaker waits before allowing a probe request.
# RESILIENCE_CB_HALF_OPEN_MS=30000

# Set to "false" to disable GET request deduplication.
# RESILIENCE_DEDUP_ENABLED=true

# How long (ms) a dedup cache entry lives after a request settles.
# RESILIENCE_DEDUP_TTL_MS=5000
