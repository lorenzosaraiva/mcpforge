// ─── Retry utilities ────────────────────────────────────────────────────────

const RETRYABLE_STATUSES = new Set([429, 500, 502, 503, 504]);

function parseRetryAfterMs(headers: Headers): number | null {
  const header = headers.get("retry-after");
  if (!header) return null;

  const seconds = parseInt(header, 10);
  if (Number.isFinite(seconds) && seconds >= 0) {
    return seconds * 1000;
  }

  const date = Date.parse(header);
  if (!Number.isNaN(date)) {
    return Math.max(0, date - Date.now());
  }

  return null;
}

function computeBackoffMs(attempt: number): number {
  const exponential = config.retryBaseMs * Math.pow(2, attempt);
  const jitter = Math.random() * config.retryBaseMs;
  return Math.min(exponential + jitter, config.retryMaxMs);
}

function sleep(ms: number): Promise<void> {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

// ─── Circuit Breaker ────────────────────────────────────────────────────────

type CBState = "CLOSED" | "OPEN" | "HALF_OPEN";

interface CircuitBreakerEntry {
  state: CBState;
  failures: number;
  openedAt: number;
}

const circuitBreakers = new Map<string, CircuitBreakerEntry>();

function getBreaker(host: string): CircuitBreakerEntry {
  let entry = circuitBreakers.get(host);
  if (!entry) {
    entry = { state: "CLOSED", failures: 0, openedAt: 0 };
    circuitBreakers.set(host, entry);
  }
  return entry;
}

function checkCircuit(host: string): void {
  const breaker = getBreaker(host);

  if (breaker.state === "OPEN") {
    const elapsed = Date.now() - breaker.openedAt;
    if (elapsed >= config.cbHalfOpenMs) {
      breaker.state = "HALF_OPEN";
    } else {
      const retryInSecs = Math.ceil((config.cbHalfOpenMs - elapsed) / 1000);
      throw new Error(`Circuit breaker OPEN for host ${host}. Retry in ${retryInSecs}s.`);
    }
  }
}

function recordSuccess(host: string): void {
  const breaker = getBreaker(host);
  breaker.state = "CLOSED";
  breaker.failures = 0;
}

function recordFailure(host: string): void {
  const breaker = getBreaker(host);
  breaker.failures += 1;
  if (breaker.failures >= config.cbThreshold) {
    breaker.state = "OPEN";
    breaker.openedAt = Date.now();
  }
}

// ─── Deduplication ──────────────────────────────────────────────────────────

interface DedupEntry {
  promise: Promise<Response>;
  timer: ReturnType<typeof setTimeout>;
}

const dedupCache = new Map<string, DedupEntry>();

function makeDedupKey(url: URL, init: RequestInit): string {
  const method = (init.method ?? "GET").toUpperCase();
  const headers = init.headers as Record<string, string> | undefined;
  const sortedHeaders = headers
    ? Object.entries(headers)
        .sort(([a], [b]) => a.localeCompare(b))
        .map(([k, v]) => `${k}:${v}`)
        .join("|")
    : "";
  return createHash("sha1")
    .update(`${method}\n${url.toString()}\n${sortedHeaders}`)
    .digest("hex");
}

function dedup(url: URL, init: RequestInit, execute: () => Promise<Response>): Promise<Response> {
  const key = makeDedupKey(url, init);

  const existing = dedupCache.get(key);
  if (existing) {
    return existing.promise.then((r) => r.clone());
  }

  const promise = execute();

  const timer = setTimeout(() => {
    dedupCache.delete(key);
  }, config.dedupTtlMs);

  const entry: DedupEntry = { promise, timer };
  dedupCache.set(key, entry);

  promise.finally(() => {
    clearTimeout(entry.timer);
    dedupCache.delete(key);
  });

  return promise;
}

// ─── Main export ─────────────────────────────────────────────────────────────

export async function resilientFetch(url: URL, init: RequestInit): Promise<Response> {
  const method = (init.method ?? "GET").toUpperCase();
  const isGet = method === "GET";
  const host = url.hostname;

  const execute = (): Promise<Response> => executeWithRetry(url, init, host);

  if (config.dedupEnabled && isGet) {
    return dedup(url, init, execute);
  }

  return execute();
}

async function executeWithRetry(url: URL, init: RequestInit, host: string): Promise<Response> {
  let lastError: Error | null = null;

  for (let attempt = 0; attempt <= config.retryMax; attempt++) {
    checkCircuit(host);

    let response: Response;
    try {
      response = await fetch(url, init);
    } catch (networkError) {
      const message = networkError instanceof Error ? networkError.message : "Unknown network failure";
      lastError = new Error(`Network error on attempt ${attempt + 1}: ${message}`);
      recordFailure(host);

      if (attempt < config.retryMax) {
        await sleep(computeBackoffMs(attempt));
        continue;
      }
      throw lastError;
    }

    if (RETRYABLE_STATUSES.has(response.status)) {
      recordFailure(host);

      if (attempt < config.retryMax) {
        const retryAfterMs = parseRetryAfterMs(response.headers);
        const backoffMs = computeBackoffMs(attempt);
        const delay = retryAfterMs !== null ? Math.max(backoffMs, retryAfterMs) : backoffMs;
        lastError = new Error(`HTTP ${response.status} on attempt ${attempt + 1}`);
        await sleep(delay);
        continue;
      }

      // Retries exhausted — return response so caller can read the error body.
      return response;
    }

    recordSuccess(host);
    return response;
  }

  throw lastError ?? new Error(`Unexpected retry loop exit for ${url.toString()}`);
}
