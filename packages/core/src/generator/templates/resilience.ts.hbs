function envInt(name: string, fallback: number): number {
  const raw = process.env[name];
  if (!raw) return fallback;
  const parsed = parseInt(raw, 10);
  return Number.isFinite(parsed) && parsed >= 0 ? parsed : fallback;
}

function envBool(name: string, fallback: boolean): boolean {
  const raw = process.env[name]?.toLowerCase().trim();
  if (!raw) return fallback;
  return raw === "1" || raw === "true" || raw === "yes";
}

const config = Object.freeze({
  retryMax:     envInt("RESILIENCE_RETRY_MAX", 3),
  retryBaseMs:  envInt("RESILIENCE_RETRY_BASE_MS", 500),
  retryMaxMs:   envInt("RESILIENCE_RETRY_MAX_MS", 30_000),
  cbThreshold:  envInt("RESILIENCE_CB_THRESHOLD", 5),
