{
  "name": "mcpforge",
  "private": true,
  "version": "1.0.0",
  "description": "Generate production-ready MCP servers from OpenAPI specs.",
  "author": "Lorenzo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/mcpforge.git"
  },
  "keywords": [
    "mcp",
    "openapi",
    "ai",
    "agent",
    "claude",
    "cursor",
    "model-context-protocol"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @mcpforge/core && npm run build -w mcpforge",
    "dev": "tsx packages/cli/src/index.ts",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
